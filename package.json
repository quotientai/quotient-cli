{
  "name": "@quotient/cli",
  "version": "0.2.1",
  "description": "Command-line interface for the Quotient SDK. Designed for humans and agents (Claude Code).",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "qt": "./dist/qt"
  },
  "engines": {
    "bun": ">=1.1"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --minify --sourcemap ./src/index.ts --outfile dist/qt",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x biome check src test",
    "format": "bun x biome format --write src test",
    "test": "bun test"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@quotientjs/server": "^0.8.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.14",
    "typescript": "^5.7.2"
  }
}
